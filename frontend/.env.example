# Frontend API base URL (required in production)
# Example: https://your-backend.onrender.com/api
VITE_API_BASE_URL=

# Multiplayer WebSocket URL (required in production)
# Example: wss://your-backend.onrender.com
VITE_WS_URL=

# Google OAuth client ID for Google sign-in
# Example: 1018194346821-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=
